# Required for embeddings and LLM summary
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Instagram login (needed for full access; rate-limit to reduce ban risk)
# INSTAGRAM_USER=
# INSTAGRAM_PASSWORD=

# Optional: proxy for scrapers (e.g. http://user:pass@host:port)
# HTTP_PROXY=
# HTTPS_PROXY=

# Optional: cache window in hours (skip re-scrape if data younger than this)
# CACHE_HOURS=24

# Optional: delay in seconds between scraper requests (rate limiting)
# RATE_LIMIT_DELAY_SECONDS=1.5
